# Copy this file to .env and fill in your values.
# Never commit .env to git — it contains secret keys.

# Supabase (get these from: supabase.com → your project → Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Affiliate IDs (get after applying to each programme)
EXPO_PUBLIC_EBAY_CAMPAIGN_ID=your-ebay-campaign-id
EXPO_PUBLIC_ETSY_AFFILIATE_ID=your-etsy-affiliate-id
